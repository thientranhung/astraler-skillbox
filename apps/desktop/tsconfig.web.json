{
  "include": [
    "renderer/src/**/*.ts",
    "renderer/src/**/*.tsx",
    "../../shared/generated/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/renderer",
    "rootDir": "../../",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@contracts/*": ["../../shared/generated/*"]
    }
  }
}
