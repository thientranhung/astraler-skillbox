{
  "name": "astraler-skillbox-desktop",
  "version": "0.1.0",
  "description": "Astraler Skillbox desktop app",
  "author": "Astraler",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit",
    "generate:contracts": "node scripts/generate-contracts.mjs",
    "check:contracts-drift": "node scripts/generate-contracts.mjs --check",
    "build:core": "node scripts/build-core.mjs",
    "package:mac": "pnpm build:core && pnpm build && electron-builder --mac dmg",
    "package:mac:unsigned": "pnpm build:core && pnpm build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg -c.mac.identity=null -c.mac.hardenedRuntime=false -c.mac.notarize=false",
    "release:mac:check": "node scripts/release-mac-check.mjs",
    "release:mac:verify": "node scripts/release-mac-verify.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "@vitejs/plugin-react": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "^7.76.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/router-devtools": "^1.167.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "happy-dom": "^20.9.0",
    "js-yaml": "^4.1.0",
    "json-schema-to-typescript": "latest",
    "tailwindcss": "^4.3.0",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "electron": "latest",
    "electron-vite": "latest",
    "electron-builder": "latest"
  }
}
